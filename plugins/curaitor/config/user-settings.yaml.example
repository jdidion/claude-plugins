# Per-user curaitor settings.
# Copy to user-settings.yaml (gitignored) and edit.
default_slack_channel: "#general"

# Obsidian vault paths for specific features. All paths are relative to the
# vault root. Skills should read from this block rather than hardcoding paths.
# Tracking ticket for threading this through all skills: https://github.com/jdidion/claude-plugins/issues/13
vault_paths:
  journal_club: "Journal Club Ideas.md"
  bookmarks: "Bookmarks.md"
  tools_and_projects: "Tools & Projects.md"
  curaitor_root: "Curaitor"       # Inbox, Review, Ignored, Archive, Recycle.md live under here
  library_root: "Library"         # Permanently-kept articles
  topics_root: "Topics"           # Topic notes
  recycle_file: "Curaitor/Recycle.md"

# Line-count trigger for auto-rotating Curaitor/Recycle.md into a monthly
# archive at Curaitor/Archive/Recycle-YYYY-MM.md. triage-write.py rolls
# over automatically when the live file exceeds this many entry lines.
# See scripts/recycle-rollover.py.
recycle_rollover_threshold: 1000

# Number of most-recent monthly Recycle archives to include in the dedup
# scan. Lower this if dedup becomes a bottleneck; raise it to catch older
# re-surfacings. Default 3 ≈ 90 days at the default rollover cadence.
recycle_archive_window: 3

# Obsidian folders that hold Topic notes. Used by triage-write.py's
# --find-leftovers scan and --attach-to-topic helper to locate topic files.
# The historical layout splits topics between "Personal/Topics" (user's
# private taxonomy) and "Topics" (shared), so both are scanned by default.
# Override if you reorganize.
topic_roots:
  - "Personal/Topics"
  - "Topics"

# Optional: a memory-frugal local model handles the first-round triage
# pass — confidently-not-interesting articles auto-skip to Ignored
# without a Claude call, saving ~40% of Claude usage per cycle. See
# scripts/local-triage.py.
#
# Default: disabled. Enable at installation via `bash scripts/setup.sh --local-triage`
# or flip `enabled` below and restart cron.
#
# Backend options:
#   `ollama` (default) — classic Ollama /api/chat at http://localhost:11434.
#   `omlx`             — oMLX's Anthropic-compat /v1/messages on Apple
#                        Silicon. Gives prefix-cache hits (~94%) on repeat
#                        triage prompts. Requires oMLX running at the given
#                        base_url and an api_key file at api_key_path (usually
#                        `~/.omlx/settings.json`).
#
# All four fields below (backend, base_url, api_key_path, model) can be
# overridden at runtime via the corresponding env vars:
# CURAITOR_LOCAL_BACKEND, CURAITOR_LOCAL_BASE_URL, CURAITOR_LOCAL_API_KEY_PATH,
# CURAITOR_LOCAL_MODEL.
local_triage:
  enabled: false
  backend: ollama
  model: huihui_ai/gemma-4-abliterated:e4b
  # For backend=ollama, base_url is http://localhost:11434 by default.
  # For backend=omlx, base_url is http://127.0.0.1:8000 by default.
  # base_url: http://localhost:11434
  # api_key_path is only used when backend=omlx.
  # api_key_path: ~/.omlx/settings.json
  # Legacy alias — only read when backend=ollama and base_url is unset.
  # ollama_host: http://localhost:11434
  # strict      — auto-skip when the local model says high-not-interested,
  #               OR when verdict=skip AND confidence=uncertain (hedged skip
  #               from the classifier prompt's HARD IGNORE categories)
  # permissive  — also pass high-interested items straight to Inbox without
  #               Claude review. Reserved for post-drift-monitor calibration;
  #               not recommended until the local model has a longer track
  #               record against your actual reading prefs.
  escalation_mode: strict

# Optional: override the summarization backend independently. If absent,
# summarize-inbox.py inherits backend/model/base_url from local_triage.
# summarize:
#   backend: omlx
#   model: gemma-4-26B-A4B-it-MLX-4bit
#   temperature: 0.2

# Optional: custom command to run on `b` (bookmark) verdict.
# If unset, bookmarks are written to `vault_paths.bookmarks` in Obsidian.
# bookmark_command: "curl -s -X POST 'https://api.raindrop.io/rest/v1/raindrop' -H 'Authorization: Bearer $RAINDROP_TOKEN' -H 'Content-Type: application/json' -d '{\"link\": \"$URL\", \"title\": \"$TITLE\"}'"

# Optional: request full text of paywalled papers via an institutional library
# service. Surfaces as a `g` (get-paper) verdict in /cu:read and /cu:review when
# the article URL looks like a paywalled journal paper (DOI, nature.com,
# sciencedirect.com, wiley.com, cell.com, jamanetwork.com, nejm.org, etc.).
# Leave this block absent (or set enabled: false) to hide the verdict.
#
# Template variables for body_template: {title}, {authors}, {journal},
# {volume}, {year}, {url}, {citation}. {citation} expands to
# `Authors. "Title." Journal, Volume (Year).` with missing pieces dropped.
# paper_request:
#   enabled: true
#   method: email
#   email: libraryrequests@example.com
#   subject: "paper request"
#   body_template: |
#     {citation}
#
#     {url}
