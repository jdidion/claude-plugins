# RSS feeds for /cu:discover
# Generate this file by importing your OPML export:
#   python scripts/import-opml.py ~/Downloads/feedly-export.opml [--folder Science]
#
# Or add feeds manually:

feeds:
  - name: bioRxiv Bioinformatics
    url: http://connect.biorxiv.org/biorxiv_xml.php?subject=bioinformatics+genetics+genomics
    category: science
    weight: 0.6         # Established — "uncertain" verdicts lean toward Review
  - name: Nature Genetics
    url: http://feeds.nature.com/ng/rss/current
    category: science
    weight: 0.3         # Probationary — "uncertain" verdicts lean toward Ignored
  # Per-feed user_agent override (for sites that block bots):
  # - name: GenomeWeb
  #   url: https://www.genomeweb.com/channel/all/rss
  #   category: science
  #   weight: 0.6
  #   user_agent: "Googlebot/2.1 (+http://www.google.com/bot.html)"

# Per-feed `fetch_via` backend (optional, default: rss):
#
#   rss       Direct RSS/Atom/RDF over HTTP (current default).
#
#   openalex  Query OpenAlex /works filtered by ISSN. Use for ex-BMC journals
#             that moved to link.springer.com and no longer expose public RSS
#             (Springer auth-redirects the legacy /articles/most-recent/rss.xml
#             URLs). No auth needed; polite-pool User-Agent is baked into
#             feeds.py. Set `issn` instead of `url`.
#   # - name: BMC Bioinformatics
#   #   fetch_via: openalex
#   #   issn: "1471-2105"
#   #   category: science
#   #   weight: 0.3

# Per-feed `weight` field (optional, advisory):
#   0.6  Established — proven signal; LLM biases "uncertain" toward Review
#   0.3  Probationary — new/unproven; LLM biases "uncertain" toward Ignored
#   0.1  Demoted — low precision; articles route straight to Ignored unless
#        the title matches inbox_title_keywords in reading-prefs.md.
# See reading-prefs.md §Feed weights for graduation/demotion thresholds.
# `/cu:status` surfaces graduation/demotion candidates automatically via
# `scripts/accuracy-metrics.py --feed-weight-candidates`.

# Per-feed `triage_mode` field (optional, default: standard routing):
#
#   high-prestige-gated  Article defaults to Ignored unless one of these
#                        bypass signals fires (see triage-rules.yaml):
#                          - inbox_keyword_match (title/summary contains a
#                            keyword from inbox_title_keywords)
#                          - in_news (OpenAlex FWCI ≥ in_news_threshold;
#                            requires DOI extractable from URL)
#                          - gemma_high_interest (Gemma classified as
#                            high-interested + read-now/save-reference)
#                        Use for top-tier general-purpose journals where
#                        most articles are outside scope but a small
#                        fraction are "everyone's talking about this."
#                        Pair with weight: 0.05 (very low default).
#   # - name: Nature
#   #   url: https://www.nature.com/nature.rss
#   #   category: science
#   #   weight: 0.05
#   #   triage_mode: high-prestige-gated
